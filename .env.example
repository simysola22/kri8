# =============================================================================
# kri8 — Environment Variables Reference
# Copy this file to .env and fill in your values.
# The app runs fully independently of Replit — all config is via env vars.
# =============================================================================

# --- Database (required) -----------------------------------------------------
# Standard PostgreSQL connection string. Works with any Postgres provider:
# Neon, Supabase, Railway, PlanetScale-compatible, local Docker, etc.
DATABASE_URL=postgresql://user:password@localhost:5432/kri8

# --- Clerk Authentication (required) -----------------------------------------
# Create a free Clerk app at https://clerk.dev
# Copy keys from: Clerk Dashboard > API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Frontend also needs the publishable key (Vite exposes VITE_* vars)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk proxy URL — only needed when your Clerk instance requires proxying.
# Set to your Render API URL + /api/__clerk for Vercel+Render deployments
# using Replit-managed Clerk or custom domains without a CNAME.
# Leave unset for standard Clerk accounts (Clerk calls its FAPI directly).
# VITE_CLERK_PROXY_URL=https://kri8-api.onrender.com/api/__clerk

# API base URL — full URL of your Render backend, no trailing slash.
# Required for Vercel frontend deploys. Leave empty for local dev
# (Vite's dev proxy handles /api/* locally).
# VITE_API_BASE_URL=https://kri8-api.onrender.com

# CORS allowed origins — comma-separated list of frontend URLs.
# Set on Render for production custom domains beyond the auto-allowed list.
# Auto-allowed without this var: localhost:*, *.replit.app, *.replit.dev, *.vercel.app
# ALLOWED_ORIGIN=https://kri8.com,https://www.kri8.com

# --- Session (required) -------------------------------------------------------
SESSION_SECRET=change-me-to-a-long-random-string

# --- Server (optional, defaults shown) ----------------------------------------
PORT=5000
BASE_PATH=/

# --- Trend Discovery (optional) -----------------------------------------------
# Provider to use: "mock" (default, no key needed) or "youtube"
TREND_PROVIDER=mock

# YouTube Data API v3 — https://console.cloud.google.com/
# Required only when TREND_PROVIDER=youtube
# Terms: https://developers.google.com/youtube/terms
# YOUTUBE_API_KEY=AIza...

# --- AI-Powered Inspiration (optional) ----------------------------------------
# OpenAI API — https://platform.openai.com/
# When set, the inspiration engine uses gpt-4o-mini for better results.
# Falls back to template-based generation if not set.
# OPENAI_API_KEY=sk-...

# --- Future Integrations (coming soon) ----------------------------------------
# TikTok for Developers — https://developers.tiktok.com/
# Requires app approval + OAuth for creator account linking
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=

# Meta (Instagram) Content Publishing API — https://developers.facebook.com/
# Requires Business App + Instagram Basic Display API
# META_APP_ID=
# META_APP_SECRET=
